# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Environment: development | production
APP_ENV=development

# Absolute or relative path to the personal info YAML file (see
# config/personal.example.yaml). Defaults to config/personal.yaml.
PERSONAL_INFO_PATH=config/personal.yaml

# SQLAlchemy database URL.
# Dev default (SQLite):      sqlite:///./data/app.db
# Prod (Docker Compose):     postgresql+psycopg://jaa:jaa@localhost:5432/jaa
DATABASE_URL=sqlite:///./data/app.db

# Redis URL — used by Celery broker + result backend (Phase 1+)
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Discord (Phase 5)
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_JOB_ALERTS=
DISCORD_WEBHOOK_JOB_REVIEW=
DISCORD_WEBHOOK_STATUS_UPDATES=
DISCORD_WEBHOOK_DAILY_DIGEST=

# ---------------------------------------------------------------------------
# LLM providers (Phase 4 — deferred in P0; leave blank)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Gmail API (Phase 6)
# ---------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json
GMAIL_TOKEN_PATH=config/gmail_token.json

# ---------------------------------------------------------------------------
# Scraping (Phase 1)
# ---------------------------------------------------------------------------
# Residential proxy URL (optional). Example: http://user:pass@gate.smartproxy.com:7000
PROXY_URL=
# Path to Playwright storage_state.json for authenticated sites
LINKEDIN_STORAGE_STATE_PATH=config/linkedin_state.json
HANDSHAKE_STORAGE_STATE_PATH=config/handshake_state.json

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
